{
  "$schema": "https://json-schema.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "tmux",
  "permissions": {
    "allow": [
      "Bash(poetry *)",
      "Bash(python *)",
      "Bash(pytest *)"
    ],
    "deny": [
      "Bash(poetry publish *)"
    ]
  }
}
